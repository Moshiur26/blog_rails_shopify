<% content_for :vite_entrypoint, "products" %>

<% products = @product_data&.dig(:products) || [] %>

<style>
    .product-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .product-item {
        background: #ffffff;
        border: 1px solid #e3e3e3;
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .product-link {
        color: #0b4e9b;
        font-weight: 600;
        text-decoration: none;
        font-size: 16px;
        line-height: 1.2;
    }

    .product-link:hover,
    .product-link:focus {
        text-decoration: underline;
    }

    .product-handle {
        font-size: 13px;
        color: #667085;
    }

    .product-cta {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #0b4e9b;
    }
</style>

<div id="react-root" data-bootstrap="<%= json_escape(@product_data.to_json) %>">
  <% if products.any? %>
    <ul class="product-list">
      <% products.each do |product| %>
        <li class="product-item">
          <%= link_to product[:title], product_qr_code_path(product[:id], shop: params[:shop], host: params[:host]), class: "product-link" %>
          <span class="product-handle"><%= product[:handle] %></span>
          <span class="product-cta">View QR code</span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>No products found.</p>
  <% end %>
</div>
