<%= form_with(model: product_batch, local: true) do |form| %>
  <% if product_batch.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(product_batch.errors.count, "error") %> prevented this batch from saving:</h2>
      <ul>
        <% product_batch.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form.hidden_field :shopify_variant_id %>

  <div class="field-group">
    <%= form.label :batch_number %>
    <%= form.text_field :batch_number, required: true %>
  </div>

  <div class="field-group">
    <%= form.label :expiry_date %>
    <%= form.date_field :expiry_date, required: true %>
  </div>

  <div class="field-group">
    <%= form.label :quantity %>
    <%= form.number_field :quantity, min: 0, step: 1, required: true %>
  </div>

  <div class="form-actions">
    <%= form.submit class: "button primary" %>
    <%= link_to "Back", batches_path(variant_id: product_batch.shopify_variant_id), class: "button secondary" %>
  </div>
<% end %>
