<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <% application_name = ShopifyApp.configuration.application_name %>
    <title><%= application_name %> (app)</title>
    <%= csp_meta_tag %>
    <%= csrf_meta_tags %>
    <% vite_entrypoint = content_for?(:vite_entrypoint) ? content_for(:vite_entrypoint) : "application" %>
    <%= vite_javascript_tag vite_entrypoint %>
  </head>

  <body>
    <div class="app-wrapper">
      <div class="app-content">
        <main role="main">
          <%= yield %>
        </main>
      </div>
    </div>

    <%= render 'layouts/flash_messages' %>

    <script src="https://unpkg.com/@shopify/app-bridge@2"></script>

    <%= content_tag(:div, nil, id: 'shopify-app-init', data: {
      api_key: ShopifyApp.configuration.api_key,
      shop_origin: @shop_origin || (@current_shopify_session.shop if @current_shopify_session),
      host: @host,
      debug: Rails.env.development?
    } ) %>
  </body>
</html>
