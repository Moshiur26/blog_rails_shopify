<style>
  .settings-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 28px 16px 48px;
  }

  .settings-card {
    background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
    border: 1px solid #d6e4f0;
    border-radius: 24px;
    padding: 24px;
    box-shadow: 0 18px 40px rgba(16, 35, 61, 0.08);
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 20px 0;
  }

  .field-group input {
    border: 1px solid #cbd5e1;
    border-radius: 12px;
    padding: 10px 12px;
    font-size: 14px;
  }

  .form-errors {
    background: #fee2e2;
    border: 1px solid #fca5a5;
    border-radius: 16px;
    padding: 14px;
    margin-bottom: 18px;
  }

  .form-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: 999px;
    padding: 10px 16px;
    border: 1px solid #114b8b;
    font-size: 14px;
    background: #ffffff;
    color: #114b8b;
  }

  .button.primary {
    background: #114b8b;
    color: #ffffff;
  }
</style>

<div class="settings-page">
  <div class="settings-card">
    <h1>Expiry Alerts</h1>
    <p>Variant: <strong><%= @variant_setting.shopify_variant_id %></strong></p>
    <p>Send alert X days before expiry.</p>

    <%= form_with(model: @variant_setting, url: variant_setting_path(@variant_setting.shopify_variant_id, app_context_params), method: :patch, local: true, data: { turbo: false }) do |form| %>
      <% if @variant_setting.errors.any? %>
        <div class="form-errors">
          <h2><%= pluralize(@variant_setting.errors.count, "error") %> prevented this setting from saving:</h2>
          <ul>
            <% @variant_setting.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="field-group">
        <%= form.label :expiry_alert_days %>
        <%= form.number_field :expiry_alert_days, min: 0, step: 1, required: true %>
      </div>

      <div class="form-actions">
        <%= form.submit "Save Settings", class: "button primary" %>
        <%= link_to "Back to Batches", batches_path({ variant_id: @variant_setting.shopify_variant_id }.merge(app_context_params)), class: "button" %>
      </div>
    <% end %>
  </div>
</div>
