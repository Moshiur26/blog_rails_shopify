<% content_for :vite_entrypoint, "products" %>

<% products = @bootstrap_data&.dig(:products) || [] %>

<style>
  .product-page {
    background: linear-gradient(180deg, #f5f7ff 0%, #ffffff 55%);
    padding: 28px 16px 36px;
  }

  .product-header {
    max-width: 920px;
    margin: 0 auto 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .product-header h1 {
    margin: 0;
    font-size: 24px;
    color: #0f172a;
  }

  .product-header p {
    margin: 4px 0 0;
    color: #64748b;
    font-size: 14px;
  }

  .product-list {
    max-width: 920px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
    list-style: none;
    padding: 0;
  }

  .product-item {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 14px;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    display: flex;
    align-items: center;
    gap: 16px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .product-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.12);
  }

  .product-thumb {
    width: 88px;
    height: 88px;
    border-radius: 14px;
    overflow: hidden;
    background: #eef2ff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .product-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-thumb-placeholder {
    font-size: 12px;
    color: #5b6aa5;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .product-meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .product-link {
    color: #0b4e9b;
    font-weight: 600;
    text-decoration: none;
    font-size: 17px;
    line-height: 1.25;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .product-link:hover,
  .product-link:focus {
    text-decoration: underline;
  }

  .product-handle {
    font-size: 13px;
    color: #667085;
  }

  .product-cta {
    margin-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #475569;
  }

  .product-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .product-button {
    text-decoration: none;
    font-size: 13px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid #0b4e9b;
    color: #0b4e9b;
    background: #ffffff;
    white-space: nowrap;
  }

  .product-button.primary {
    background: #0b4e9b;
    color: #ffffff;
  }

  .product-pagination {
    max-width: 920px;
    margin: 22px auto 0;
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .page-button {
    text-decoration: none;
    font-size: 14px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid #0b4e9b;
    color: #0b4e9b;
  }

  .page-button.disabled {
    opacity: 0.5;
    pointer-events: none;
  }
</style>

<div id="react-root" class="product-page" data-bootstrap="<%= json_escape(@bootstrap_data.to_json) %>">
  <% if products.any? %>
    <div class="product-header">
      <div>
        <h1>Products</h1>
        <p>Choose a product to generate its QR code.</p>
      </div>
    </div>
    <ul class="product-list">
      <% products.each do |product| %>
        <li class="product-item">
          <div class="product-thumb">
            <% if product[:image_url].present? %>
              <img src="<%= product[:image_url] %>" alt="<%= product[:title] %> image">
            <% else %>
              <span class="product-thumb-placeholder">No image</span>
            <% end %>
          </div>
          <div class="product-meta">
            <%= link_to product[:title], product_qr_code_path(product[:id], shop: params[:shop], host: params[:host]), class: "product-link" %>
            <span class="product-handle"><%= product[:handle] %></span>
            <span class="product-cta">Tap to open the QR code page.</span>
          </div>
          <div class="product-actions">
            <%= link_to "View QR", product_qr_code_path(product[:id], shop: params[:shop], host: params[:host]), class: "product-button primary" %>
            <%= link_to "Open Product", "https://#{@bootstrap_data&.dig(:shopOrigin)}/products/#{product[:handle]}", class: "product-button", target: "_blank", rel: "noopener" %>
            <% if product[:primary_variant_id].present? %>
              <%= link_to "Expiry Settings", edit_variant_setting_path(product[:primary_variant_id], app_context_params), class: "product-button" %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="product-pagination">
      <% if @prev_page_info.present? %>
        <%= link_to "Previous", products_path(shop: params[:shop], host: params[:host], page_info: @prev_page_info, limit: @page_limit), class: "page-button" %>
      <% else %>
        <span class="page-button disabled">Previous</span>
      <% end %>

      <% if @next_page_info.present? %>
        <%= link_to "Next", products_path(shop: params[:shop], host: params[:host], page_info: @next_page_info, limit: @page_limit), class: "page-button" %>
      <% else %>
        <span class="page-button disabled">Next</span>
      <% end %>
    </div>
  <% else %>
    <p>No products found.</p>
  <% end %>
</div>
